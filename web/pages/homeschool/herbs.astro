// Rendered as two labeled grids, in curriculum order.
const herbGroups = [
  { title: "Sprouts Herbs", subtitle: "Grades K-2 · 36 herbs", programs: SPROUTS_PROGRAMS, herbs: sproutsHerbs },
  { title: "Seedlings Herbs", subtitle: "Grades 3-5 · 36 herbs", programs: SEEDLINGS_PROGRAMS, herbs: seedlingsHerbs },
