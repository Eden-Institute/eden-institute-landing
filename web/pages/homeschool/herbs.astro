---
// /homeschool/herbs - Eden's Table herb sourcing page for parents.
// Static, pre-rendered marketing page: parents order every herb used across the
// curriculum programs from one place. Two batches: the 36 Sprouts-tier herbs
// (Grades K-2, curriculum/week order) and the 36 Seedlings-tier herbs (Grades
// 3-5, alphabetical). Most link to the Mountain Rose Herbs affiliate program
// (AspireIQ short links); 3 Sprouts herbs link to Amazon (not stocked by MRH in
// dried tea form). Conventions mirror community.astro.
import MarketingLayout from "../../layouts/MarketingLayout.astro";
import { Button } from "@/components/ui/button";
import { Leaf, ShoppingCart } from "lucide-react";

