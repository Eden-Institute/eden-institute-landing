---
// /preorder — Eden's Table storefront (preorder Phase 1 + fulfillment Phase 2).
// The hero is static; EVERYTHING mode-dependent (product cards, buy buttons, SMS
// consent, and the compliance terms) renders inside the PreorderBuyBox island, keyed
// off products_public.is_preorder read live from the DB. Flipping is_preorder changes
// the storefront copy with no code edit. Terms live in the island so terms and buy
// buttons always render together: no JS means no buy button, so a buyer can never
// reach Stripe without having had the terms on screen.
//
// Compliance (FTC Mail Order Rule; copy uses no em dashes):
//   - founding-preorder framing ($100-off claim on the KIT only)
//   - estimated ship window, stated as an estimate, BEFORE redirect to Stripe
//   - card charged today + notify-and-refund right if we cannot ship in window
//   - flat $12 shipping disclosed before redirect (PREORDER_FLAT_SHIPPING_CENTS)
import MarketingLayout from "../layouts/MarketingLayout.astro";
import PreorderBuyBox from "../components/islands/PreorderBuyBox.tsx";

const SHIP_WINDOW = "Winter 2026"; // keep in sync with supabase/functions/_shared/order-config.ts

const meta = {
  title: "Founding Preorder — Eden's Table Sprouts | The Eden Institute",
  description:
    "Preorder the Sprouts (K-2) Biblical herbalism curriculum at the founding price. $100 below retail on the complete kit, founding-member status, estimated ship window " + SHIP_WINDOW + ".",
  canonical: "https://edeninstitute.health/preorder",
};
---

<MarketingLayout title={meta.title} description={meta.description} canonical={meta.canonical}>
  {/* HERO */}
  <section class="pt-20 pb-12 px-6" style="background-color:hsl(var(--eden-cream))">
    <div class="max-w-3xl mx-auto text-center">
      <p class="font-accent text-sm tracking-[0.3em] uppercase mb-4" style="color:hsl(var(--eden-gold))">
        Eden's Table
      </p>
      <h1 class="font-serif text-4xl md:text-5xl font-bold leading-tight mb-6" style="color:hsl(var(--eden-bark))">
        Be one of the founding 500 families.
      </h1>
      <div class="w-16 h-px mx-auto my-6" style="background-color:hsl(var(--eden-gold))"></div>
      <p class="font-body text-lg text-muted-foreground leading-relaxed max-w-2xl mx-auto">
        The founding cohort receives $100 off the complete kit and founding-member status,
        including a voice in shaping Seedlings and first look at every band that follows.
      </p>
    </div>
  </section>

  {/* BUY BOX + TERMS (one island; copy keyed off products_public.is_preorder) */}
  <section class="py-12 px-6 bg-background">
    <div class="max-w-5xl mx-auto">
      <PreorderBuyBox client:only="react" />
    </div>
  </section>
</MarketingLayout>
