---
// Sprouts + Seedlings free-preview CTA pair. Static buttons (rendered by Astro
// for SEO) carrying data-waitlist-* attributes; WaitlistController wires the
// clicks to the modal. Mirrors the DualLeadMagnetCTAs helper in Homeschool.tsx.
import { Button } from "@/components/ui/button";

interface Props {
  size?: "lg" | "xl";
  variant?: "eden" | "eden-outline";
}
const { size = "lg", variant = "eden-outline" } = Astro.props;

const sproutsSubtitle =
  "Check your inbox — your free Sprouts Week 1 (Lavender) downloads are on their way right now. Five real lessons to print and teach today. Week 2 (Chamomile) follows in seven days.";
const seedlingsSubtitle =
  "Check your inbox — your free Seedlings Week 1 (Elderberry) downloads are on their way right now. Five real lessons to print and teach today. Week 2 (Tulsi) follows in seven days.";
---

<div class="flex flex-col sm:flex-row gap-3 justify-center items-stretch">
  <Button
    variant={variant}
    size={size}
    data-waitlist-source="sprouts_magnet"
    data-waitlist-title="Get Sprouts Weeks 1 + 2 — Free"
    data-waitlist-subtitle={sproutsSubtitle}
  >
    Get Sprouts (K-2) Weeks 1 + 2 — Free
  </Button>
  <Button
    variant={variant}
    size={size}
    data-waitlist-source="seedlings_magnet"
    data-waitlist-title="Get Seedlings Weeks 1 + 2 — Free"
    data-waitlist-subtitle={seedlingsSubtitle}
  >
    Get Seedlings (3-5) Weeks 1 + 2 — Free
  </Button>
</div>
